rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUsuarioAtivo() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && (
          !("status" in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.status == "Ativo"
        );
    }

    function perfilDoc() {
      return hasUsuarioAtivo()
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil
        : null;
    }

    function supermercadoDoc() {
      return hasUsuarioAtivo()
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id
        : null;
    }

    function perfil() {
      return isSignedIn()
        ? (perfilDoc() != null
            ? perfilDoc()
            : (request.auth.token.perfil != null
                ? request.auth.token.perfil
                : null))
        : null;
    }

    function supermercadoClaim() {
      return isSignedIn()
        ? (supermercadoDoc() != null
            ? supermercadoDoc()
            : (request.auth.token.supermercado_id != null
                ? request.auth.token.supermercado_id
                : null))
        : null;
    }

    function isAdminGeral() {
      return perfil() == "Administrador Geral";
    }

    function isPerfilValido(perfilInput) {
      return perfilInput == "Promotor"
        || perfilInput == "Funcionário"
        || perfilInput == "Operador"
        || perfilInput == "Supervisor"
        || perfilInput == "Administrador Geral";
    }

    function isSupermercadoVinculoValido(perfilInput, supermercadoId) {
      return (
        perfilInput == "Administrador Geral"
        && (
          supermercadoId == null
          || (supermercadoId is string && supermercadoId.size() > 0)
        )
      ) || (
        perfilInput != "Administrador Geral"
        && supermercadoId is string
        && supermercadoId.size() > 0
      );
    }

    function isSupervisor() {
      return perfil() == "Supervisor";
    }

    function isOperador() {
      return perfil() == "Operador";
    }

    function isPromotorOuFuncionario() {
      return perfil() == "Promotor" || perfil() == "Funcionário";
    }

    function isSupermercadoAtivo(supermercadoId) {
      return supermercadoId is string
        && supermercadoId.size() > 0
        && exists(/databases/$(database)/documents/supermercados/$(supermercadoId))
        && get(/databases/$(database)/documents/supermercados/$(supermercadoId)).data.status == "Ativo";
    }

    function isMesmaUnidade(unidadeId) {
      return supermercadoClaim() != null && unidadeId == supermercadoClaim();
    }

    function isTextoNaoVazio(valor) {
      return valor is string && valor.size() > 0;
    }

    function isCampoVazio(valor) {
      return valor == null || (valor is string && valor.size() == 0);
    }

    function isStatusChamadoValido(status) {
      return status == "Aguardando"
        || status == "Em atendimento"
        || status == "Finalizado";
    }

    function isPrioridadeValida(prioridade) {
      return prioridade == "Normal" || prioridade == "Urgente";
    }

    function isTipoServicoValido(tipo) {
      return tipo == "Descarga"
        || tipo == "Reposição"
        || tipo == "Retirada"
        || tipo == "Movimentação";
    }

    function isChamadoBaseValido(data) {
      return isTextoNaoVazio(data.id)
        && isTextoNaoVazio(data.supermercado_id)
        && isTextoNaoVazio(data.solicitante_nome)
        && isTextoNaoVazio(data.setor)
        && isTipoServicoValido(data.tipo_servico)
        && isPrioridadeValida(data.prioridade)
        && isStatusChamadoValido(data.status)
        && isTextoNaoVazio(data.criado_em)
        && (isCampoVazio(data.operador_nome) || isTextoNaoVazio(data.operador_nome))
        && (isCampoVazio(data.iniciado_em) || isTextoNaoVazio(data.iniciado_em))
        && (isCampoVazio(data.finalizado_em) || isTextoNaoVazio(data.finalizado_em));
    }

    function isCriacaoChamadoValida() {
      return isChamadoBaseValido(request.resource.data)
        && request.resource.data.status == "Aguardando"
        && request.resource.data.operador_nome == null
        && request.resource.data.iniciado_em == null
        && request.resource.data.finalizado_em == null;
    }

    function isAtualizacaoOperacionalPermitida() {
      return request.resource.data.supermercado_id == resource.data.supermercado_id
        && request.resource.data.solicitante_nome == resource.data.solicitante_nome
        && request.resource.data.setor == resource.data.setor
        && request.resource.data.tipo_servico == resource.data.tipo_servico
        && request.resource.data.prioridade == resource.data.prioridade
        && request.resource.data.criado_em == resource.data.criado_em
        && (
          request.resource.data.id == resource.data.id
          || (
            !("id" in resource.data)
            && !("id" in request.resource.data)
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "operador_nome",
          "iniciado_em",
          "finalizado_em",
          "atualizado_em"
        ])
        && isStatusChamadoValido(request.resource.data.status)
        && (
          isCampoVazio(request.resource.data.operador_nome)
          || isTextoNaoVazio(request.resource.data.operador_nome)
        )
        && (request.resource.data.iniciado_em == null || request.resource.data.iniciado_em is string)
        && (request.resource.data.finalizado_em == null || request.resource.data.finalizado_em is string);
    }

    function isTransicaoStatusPermitida() {
      return (
        resource.data.status == "Aguardando"
        && (
          request.resource.data.status == "Aguardando"
          || (
            request.resource.data.status == "Em atendimento"
            && request.resource.data.iniciado_em != null
            && isCampoVazio(request.resource.data.finalizado_em)
          )
        )
      ) || (
        resource.data.status == "Em atendimento"
        && (
          request.resource.data.status == "Em atendimento"
          || (
            request.resource.data.status == "Finalizado"
            && request.resource.data.iniciado_em != null
            && request.resource.data.finalizado_em != null
          )
        )
      ) || (
        resource.data.status == "Finalizado"
        && request.resource.data.status == "Finalizado"
      ) || (
        !isStatusChamadoValido(resource.data.status)
        && (
          request.resource.data.status == "Aguardando"
          || (
            request.resource.data.status == "Em atendimento"
            && request.resource.data.iniciado_em != null
            && isCampoVazio(request.resource.data.finalizado_em)
          )
          || (
            request.resource.data.status == "Finalizado"
            && request.resource.data.iniciado_em != null
            && request.resource.data.finalizado_em != null
          )
        )
      );
    }

    function isAssumirChamadoPermitido() {
      return isAtualizacaoOperacionalPermitida()
        && resource.data.status == "Aguardando"
        && request.resource.data.status == "Aguardando"
        && isCampoVazio(resource.data.operador_nome)
        && isTextoNaoVazio(request.resource.data.operador_nome)
        && isCampoVazio(request.resource.data.iniciado_em)
        && isCampoVazio(request.resource.data.finalizado_em);
    }

    match /chamados/{id} {
      allow read: if isAdminGeral() || isMesmaUnidade(resource.data.supermercado_id);

      allow create: if (
        (isAdminGeral()
          && request.resource.data.id == id
          && isCriacaoChamadoValida())
        || (
          isPromotorOuFuncionario()
          && request.resource.data.id == id
          && isCriacaoChamadoValida()
          && isMesmaUnidade(request.resource.data.supermercado_id)
        )
      );

      allow update: if (
        isAdminGeral()
        || (
          hasUsuarioAtivo()
          && isAtualizacaoOperacionalPermitida()
          && isTransicaoStatusPermitida()
          && isMesmaUnidade(resource.data.supermercado_id)
          && isMesmaUnidade(request.resource.data.supermercado_id)
        )
      );

      allow delete: if isAdminGeral();
    }

    match /supermercados/{id} {
      allow read: if true;
      allow write: if isAdminGeral();
    }

    match /usuarios/{id} {
      allow read: if isAdminGeral() || (isSignedIn() && request.auth.uid == id);

      allow create: if isSignedIn()
        && request.auth.uid == id
        && request.resource.data.id == request.auth.uid
        && request.resource.data.status == "Ativo"
        && isPerfilValido(request.resource.data.perfil)
        && isSupermercadoVinculoValido(
          request.resource.data.perfil,
          request.resource.data.supermercado_id
        );

      allow update: if isAdminGeral()
        || (
          isSignedIn()
          && request.auth.uid == id
          && request.resource.data.perfil == resource.data.perfil
          && request.resource.data.status == resource.data.status
          && (
            request.resource.data.supermercado_id == resource.data.supermercado_id
            || (
              resource.data.perfil == "Operador"
              && isSupermercadoAtivo(request.resource.data.supermercado_id)
            )
          )
        );

      allow delete: if isAdminGeral();
    }
  }
}
