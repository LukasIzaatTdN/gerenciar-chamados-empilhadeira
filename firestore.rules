rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminGeral() {
      return isSignedIn()
        && request.auth.token.perfil == "Administrador Geral";
    }

    function isAdminGeralByUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == "Administrador Geral"
        && (
          !("status" in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.status == "Ativo"
        );
    }

    function hasAdminManagementAccess() {
      return isAdminGeral() || isAdminGeralByUserDoc();
    }

    function isPerfilValido(perfilInput) {
      return perfilInput == "Promotor"
        || perfilInput == "Funcionário"
        || perfilInput == "Operador"
        || perfilInput == "Supervisor"
        || perfilInput == "Televendas"
        || perfilInput == "Administrador Geral";
    }

    function isSupermercadoAtivo(supermercadoId) {
      return supermercadoId is string
        && supermercadoId.size() > 0
        && exists(/databases/$(database)/documents/supermercados/$(supermercadoId))
        && get(/databases/$(database)/documents/supermercados/$(supermercadoId)).data.status == "Ativo";
    }

    function isSupermercadoVinculoValido(perfilInput, supermercadoId) {
      return (
        perfilInput == "Administrador Geral"
        && (
          supermercadoId == null
          || isSupermercadoAtivo(supermercadoId)
        )
      ) || (
        perfilInput != "Administrador Geral"
        && isSupermercadoAtivo(supermercadoId)
      );
    }

    function isTextoNaoVazio(valor) {
      return valor is string && valor.size() > 0;
    }

    function isCampoVazio(valor) {
      return valor == null || (valor is string && valor.size() == 0);
    }

    function isNumeroNaoNegativo(valor) {
      return valor is int || valor is float
        ? valor >= 0
        : false;
    }

    function isNumeroOpcionalNaoNegativo(valor) {
      return valor == null || isNumeroNaoNegativo(valor);
    }

    function isListaItensTelevendasValida(valor) {
      return valor is list;
    }

    function isStatusChamadoValido(status) {
      return status == "Aguardando"
        || status == "Em atendimento"
        || status == "Finalizado"
        || status == "Aberto"
        || status == "Em separação"
        || status == "Incompleto"
        || status == "Pronto"
        || status == "Cancelado";
    }

    function isPrioridadeValida(prioridade) {
      return prioridade == "Normal" || prioridade == "Urgente";
    }

    function isTipoServicoValido(tipo) {
      return tipo == "Descarga"
        || tipo == "Reposição"
        || tipo == "Retirada"
        || tipo == "Movimentação"
        || tipo == "Apoio interno"
        || tipo == "Atendimento Televendas";
    }

    function isCategoriaValida(categoria) {
      return categoria == "operacional" || categoria == "televendas";
    }

    function isChamadoBaseValido(data) {
      return isTextoNaoVazio(data.id)
        && isCategoriaValida(data.categoria)
        && isTextoNaoVazio(data.supermercado_id)
        && isTextoNaoVazio(data.solicitante_nome)
        && isTextoNaoVazio(data.setor)
        && isTipoServicoValido(data.tipo_servico)
        && (isCampoVazio(data.numero_pedido) || isTextoNaoVazio(data.numero_pedido))
        && (isCampoVazio(data.cliente) || isTextoNaoVazio(data.cliente))
        && (isCampoVazio(data.produto) || isTextoNaoVazio(data.produto))
        && (isCampoVazio(data.quantidade) || isTextoNaoVazio(data.quantidade))
        && isListaItensTelevendasValida(data.itens)
        && isNumeroOpcionalNaoNegativo(data.total_solicitado)
        && isNumeroOpcionalNaoNegativo(data.total_encontrado)
        && isNumeroOpcionalNaoNegativo(data.percentual_atendido)
        && (isCampoVazio(data.motivo_incompleto) || isTextoNaoVazio(data.motivo_incompleto))
        && (isCampoVazio(data.observacao_operador) || isTextoNaoVazio(data.observacao_operador))
        && (isCampoVazio(data.local_separacao) || isTextoNaoVazio(data.local_separacao))
        && (isCampoVazio(data.prazo_limite) || isTextoNaoVazio(data.prazo_limite))
        && isPrioridadeValida(data.prioridade)
        && isStatusChamadoValido(data.status)
        && isTextoNaoVazio(data.criado_em)
        && (isCampoVazio(data.assumido_em) || isTextoNaoVazio(data.assumido_em))
        && (isCampoVazio(data.a_caminho_em) || isTextoNaoVazio(data.a_caminho_em))
        && (isCampoVazio(data.cheguei_em) || isTextoNaoVazio(data.cheguei_em))
        && (isCampoVazio(data.operador_nome) || isTextoNaoVazio(data.operador_nome))
        && (isCampoVazio(data.atualizado_em) || isTextoNaoVazio(data.atualizado_em))
        && (isCampoVazio(data.atualizado_por) || isTextoNaoVazio(data.atualizado_por))
        && (isCampoVazio(data.iniciado_em) || isTextoNaoVazio(data.iniciado_em))
        && (isCampoVazio(data.finalizado_em) || isTextoNaoVazio(data.finalizado_em))
        && (isCampoVazio(data.cancelado_em) || isTextoNaoVazio(data.cancelado_em));
    }

    function isCriacaoChamadoValida() {
      return isChamadoBaseValido(request.resource.data)
        && (
          (request.resource.data.categoria == "operacional" && request.resource.data.status == "Aguardando")
          || (request.resource.data.categoria == "televendas" && request.resource.data.status == "Aberto")
        )
        && request.resource.data.operador_nome == null
        && request.resource.data.assumido_em == null
        && request.resource.data.a_caminho_em == null
        && request.resource.data.cheguei_em == null
        && request.resource.data.iniciado_em == null
        && request.resource.data.finalizado_em == null
        && request.resource.data.cancelado_em == null
        && request.resource.data.atualizado_em == null
        && request.resource.data.atualizado_por == null
        && request.resource.data.motivo_incompleto == null
        && request.resource.data.observacao_operador == null;
    }

    function isAtualizacaoChamadoValida() {
      return isChamadoBaseValido(request.resource.data)
        && request.resource.data.categoria == resource.data.categoria
        && request.resource.data.supermercado_id == resource.data.supermercado_id
        && request.resource.data.id == resource.data.id
        && request.resource.data.solicitante_nome == resource.data.solicitante_nome
        && request.resource.data.setor == resource.data.setor
        && request.resource.data.tipo_servico == resource.data.tipo_servico
        && request.resource.data.numero_pedido == resource.data.numero_pedido
        && request.resource.data.cliente == resource.data.cliente
        && request.resource.data.local_separacao == resource.data.local_separacao
        && request.resource.data.prazo_limite == resource.data.prazo_limite
        && request.resource.data.prioridade == resource.data.prioridade
        && request.resource.data.criado_em == resource.data.criado_em
        && isStatusChamadoValido(request.resource.data.status);
    }

    match /chamados/{id} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.id == id
        && isCriacaoChamadoValida()
        && (isAdminGeral() || isSupermercadoAtivo(request.resource.data.supermercado_id));

      allow update: if isSignedIn()
        && isAtualizacaoChamadoValida();

      allow delete: if isAdminGeral();
    }

    match /supermercados/{id} {
      allow read: if true;
      allow write: if hasAdminManagementAccess();
    }

    match /usuarios/{id} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.auth.uid == id
        && request.resource.data.id == request.auth.uid
        && request.resource.data.status == "Ativo"
        && isPerfilValido(request.resource.data.perfil)
        && isSupermercadoVinculoValido(
          request.resource.data.perfil,
          request.resource.data.supermercado_id
        );

      allow update: if hasAdminManagementAccess()
        || (
          isSignedIn()
          && request.auth.uid == id
          && request.resource.data.id == resource.data.id
          && request.resource.data.nome == resource.data.nome
          && request.resource.data.email == resource.data.email
          && request.resource.data.perfil == resource.data.perfil
          && request.resource.data.status == resource.data.status
          && request.resource.data.criado_em == resource.data.criado_em
          && (
            request.resource.data.supermercado_id == resource.data.supermercado_id
            || isSupermercadoAtivo(request.resource.data.supermercado_id)
            || (resource.data.perfil == "Administrador Geral" && request.resource.data.supermercado_id == null)
          )
        );

      allow delete: if hasAdminManagementAccess();
    }
  }
}
