rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminGeral() {
      return isSignedIn()
        && request.auth.token.perfil == "Administrador Geral";
    }

    function isAdminGeralByUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == "Administrador Geral"
        && (
          !("status" in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.status == "Ativo"
        );
    }

    function isAdminEmpresa() {
      return isSignedIn()
        && request.auth.token.perfil == "Administrador da Empresa";
    }

    function isAdminEmpresaByUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil == "Administrador da Empresa"
        && (
          !("status" in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.status == "Ativo"
        );
    }

    function hasAdminManagementAccess() {
      return isAdminGeral() || isAdminGeralByUserDoc() || isAdminEmpresa() || isAdminEmpresaByUserDoc();
    }

    function isPlatformAdminAccess() {
      return isAdminGeral() || isAdminGeralByUserDoc();
    }

    function currentUserEmpresaId() {
      return isSignedIn()
        ? (
            exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.empresa_id != null
            ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.empresa_id
            : (
                exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
                && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id is string
                && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id.size() > 0
                && exists(
                  /databases/$(database)/documents/supermercados/$(get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id)
                )
                ? get(
                    /databases/$(database)/documents/supermercados/$(get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id)
                  ).data.empresa_id
                : (
                    request.auth.token.empresa_id is string
                    && request.auth.token.empresa_id.size() > 0
                    ? request.auth.token.empresa_id
                    : null
                  )
              )
          )
        : null;
    }

    function currentUserSupermercadoId() {
      return isSignedIn()
        ? (
            exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id != null
            ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.supermercado_id
            : (
                request.auth.token.supermercado_id is string
                && request.auth.token.supermercado_id.size() > 0
                ? request.auth.token.supermercado_id
                : null
              )
          )
        : null;
    }

    function currentUserPerfil() {
      return isSignedIn()
        ? (
            exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil != null
            ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil
            : (
                request.auth.token.perfil is string
                && request.auth.token.perfil.size() > 0
                ? request.auth.token.perfil
                : null
              )
          )
        : null;
    }

    function isSupervisorDaUnidade(supermercadoId) {
      return isSignedIn()
        && currentUserPerfil() == "Supervisor"
        && currentUserSupermercadoId() != null
        && currentUserSupermercadoId() == supermercadoId;
    }

    function isAdminEmpresaDaEmpresa(empresaId) {
      return isSignedIn()
        && currentUserPerfil() == "Administrador da Empresa"
        && currentUserEmpresaId() != null
        && currentUserEmpresaId() == empresaId;
    }

    function isPerfilValido(perfilInput) {
      return perfilInput == "Promotor"
        || perfilInput == "Funcionário"
        || perfilInput == "Operador"
        || perfilInput == "Supervisor"
        || perfilInput == "Televendas"
        || perfilInput == "Administrador da Empresa"
        || perfilInput == "Administrador Geral";
    }

    function isEmpresaAtiva(empresaId) {
      return empresaId is string
        && empresaId.size() > 0
        && exists(/databases/$(database)/documents/empresas/$(empresaId))
        && get(/databases/$(database)/documents/empresas/$(empresaId)).data.status == "Ativa";
    }

    function isSupermercadoAtivo(supermercadoId) {
      return supermercadoId is string
        && supermercadoId.size() > 0
        && exists(/databases/$(database)/documents/supermercados/$(supermercadoId))
        && get(/databases/$(database)/documents/supermercados/$(supermercadoId)).data.status == "Ativo";
    }

    function isSupermercadoDaEmpresaAtivo(empresaId, supermercadoId) {
      return isEmpresaAtiva(empresaId)
        && isSupermercadoAtivo(supermercadoId)
        && get(/databases/$(database)/documents/supermercados/$(supermercadoId)).data.empresa_id == empresaId;
    }

    function isEmpresaVinculoValido(perfilInput, empresaId) {
      return (
        perfilInput == "Administrador Geral" && empresaId == null
      ) || (
        perfilInput != "Administrador Geral" && isEmpresaAtiva(empresaId)
      );
    }

    function isSupermercadoVinculoValido(perfilInput, empresaId, supermercadoId) {
      return (
        perfilInput == "Administrador Geral"
        && (
          supermercadoId == null
          || isSupermercadoDaEmpresaAtivo(empresaId, supermercadoId)
        )
      ) || (
        perfilInput == "Administrador da Empresa"
        && supermercadoId == null
        && isEmpresaAtiva(empresaId)
      ) || (
        perfilInput != "Administrador Geral"
        && perfilInput != "Administrador da Empresa"
        && isSupermercadoDaEmpresaAtivo(empresaId, supermercadoId)
      );
    }

    function canAccessEmpresa(empresaId) {
      return isAdminGeral()
        || isAdminGeralByUserDoc()
        || isAdminEmpresaDaEmpresa(empresaId)
        || (currentUserEmpresaId() != null && currentUserEmpresaId() == empresaId);
    }

    function isTextoNaoVazio(valor) {
      return valor is string && valor.size() > 0;
    }

    function isCampoVazio(valor) {
      return valor == null || (valor is string && valor.size() == 0);
    }

    function isNumeroNaoNegativo(valor) {
      return valor is int || valor is float
        ? valor >= 0
        : false;
    }

    function isNumeroOpcionalNaoNegativo(valor) {
      return valor == null || isNumeroNaoNegativo(valor);
    }

    function isListaItensTelevendasValida(valor) {
      return valor is list;
    }

    function isStatusChamadoValido(status) {
      return status == "Aguardando"
        || status == "Em atendimento"
        || status == "Finalizado"
        || status == "Aberto"
        || status == "Em separação"
        || status == "Incompleto"
        || status == "Pronto"
        || status == "Cancelado";
    }

    function isPrioridadeValida(prioridade) {
      return prioridade == "Normal" || prioridade == "Urgente";
    }

    function isTipoServicoValido(tipo) {
      return tipo == "Descarga"
        || tipo == "Reposição"
        || tipo == "Retirada"
        || tipo == "Movimentação"
        || tipo == "Apoio interno"
        || tipo == "Atendimento Televendas";
    }

    function isCategoriaValida(categoria) {
      return categoria == "operacional" || categoria == "televendas";
    }

    function isStatusEmpilhadeiraValido(status) {
      return status == "Disponível"
        || status == "Em uso"
        || status == "Em manutenção"
        || status == "Inativa"
        || status == "Necessita atenção"
        || status == "Reserva";
    }

    function isStatusEmpilhadeiraCompativelComChamado(status) {
      return status == "Disponível"
        || status == "Em uso"
        || status == "Reserva";
    }

    function isEmpilhadeiraValida(data, id) {
      return data.id == id
        && isTextoNaoVazio(data.empresa_id)
        && isSupermercadoDaEmpresaAtivo(data.empresa_id, data.supermercado_id)
        && isTextoNaoVazio(data.identificacao)
        && isTextoNaoVazio(data.modelo)
        && isTextoNaoVazio(data.numero_interno)
        && isStatusEmpilhadeiraValido(data.status)
        && (isCampoVazio(data.observacoes) || isTextoNaoVazio(data.observacoes))
        && isTextoNaoVazio(data.criado_em)
        && isTextoNaoVazio(data.atualizado_em);
    }

    function isChecklistEmpilhadeiraValido(data, id) {
      return data.id == id
        && isSupermercadoDaEmpresaAtivo(data.empresa_id, data.supermercado_id)
        && isTextoNaoVazio(data.empilhadeira_id)
        && exists(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id))
        && get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.empresa_id == data.empresa_id
        && get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.supermercado_id == data.supermercado_id
        && isTextoNaoVazio(data.operador_id)
        && isTextoNaoVazio(data.operador_nome)
        && isTextoNaoVazio(data.data)
        && data.bateria_ok is bool
        && data.garfo_ok is bool
        && data.pneus_ok is bool
        && data.freio_ok is bool
        && data.sem_avaria is bool
        && data.reprovado is bool
        && data.itens_reprovados is list
        && (isCampoVazio(data.ocorrencia_tecnica) || isTextoNaoVazio(data.ocorrencia_tecnica))
        && (isCampoVazio(data.observacoes) || isTextoNaoVazio(data.observacoes))
        && (isCampoVazio(data.tratado_em) || isTextoNaoVazio(data.tratado_em))
        && (isCampoVazio(data.tratado_por) || isTextoNaoVazio(data.tratado_por))
        && isTextoNaoVazio(data.criado_em);
    }

    function canCreateChecklistEmpilhadeira(data) {
      return hasAdminManagementAccess()
        || (
          isSignedIn()
          && currentUserSupermercadoId() != null
          && currentUserSupermercadoId() == data.supermercado_id
        );
    }

    function isTipoManutencaoValido(tipo) {
      return tipo == "Preventiva"
        || tipo == "Corretiva"
        || tipo == "Inspecao"
        || tipo == "Revisao"
        || tipo == "Bateria";
    }

    function isPrioridadeManutencaoValida(prioridade) {
      return prioridade == "Baixa"
        || prioridade == "Media"
        || prioridade == "Alta"
        || prioridade == "Critica";
    }

    function isStatusManutencaoValido(status) {
      return status == "Aberta"
        || status == "Em andamento"
        || status == "Concluida"
        || status == "Cancelada";
    }

    function isManutencaoValida(data, id) {
      return data.id == id
        && isSupermercadoDaEmpresaAtivo(data.empresa_id, data.supermercado_id)
        && isTextoNaoVazio(data.empilhadeira_id)
        && exists(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id))
        && get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.empresa_id == data.empresa_id
        && get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.supermercado_id == data.supermercado_id
        && isTipoManutencaoValido(data.tipo)
        && isTextoNaoVazio(data.descricao)
        && isPrioridadeManutencaoValida(data.prioridade)
        && isStatusManutencaoValido(data.status)
        && (isCampoVazio(data.responsavel) || isTextoNaoVazio(data.responsavel))
        && isTextoNaoVazio(data.data_abertura)
        && (isCampoVazio(data.data_prevista) || isTextoNaoVazio(data.data_prevista))
        && (isCampoVazio(data.data_conclusao) || isTextoNaoVazio(data.data_conclusao))
        && isTextoNaoVazio(data.criado_por)
        && (isCampoVazio(data.observacoes) || isTextoNaoVazio(data.observacoes));
    }

    function canCreateManutencao(data) {
      return hasAdminManagementAccess()
        || isSupervisorDaUnidade(data.supermercado_id)
        || (
          isSignedIn()
          && currentUserSupermercadoId() != null
          && currentUserSupermercadoId() == data.supermercado_id
        );
    }

    function canUpdateManutencao(data) {
      return hasAdminManagementAccess() || isSupervisorDaUnidade(data.supermercado_id);
    }

    function isChamadoBaseValido(data) {
      return isTextoNaoVazio(data.id)
        && isCategoriaValida(data.categoria)
        && isTextoNaoVazio(data.empresa_id)
        && isSupermercadoDaEmpresaAtivo(data.empresa_id, data.supermercado_id)
        && isTextoNaoVazio(data.supermercado_id)
        && isTextoNaoVazio(data.solicitante_nome)
        && isTextoNaoVazio(data.setor)
        && isTipoServicoValido(data.tipo_servico)
        && (isCampoVazio(data.numero_pedido) || isTextoNaoVazio(data.numero_pedido))
        && (isCampoVazio(data.cliente) || isTextoNaoVazio(data.cliente))
        && (isCampoVazio(data.produto) || isTextoNaoVazio(data.produto))
        && (isCampoVazio(data.quantidade) || isTextoNaoVazio(data.quantidade))
        && isListaItensTelevendasValida(data.itens)
        && isNumeroOpcionalNaoNegativo(data.total_solicitado)
        && isNumeroOpcionalNaoNegativo(data.total_encontrado)
        && isNumeroOpcionalNaoNegativo(data.percentual_atendido)
        && (isCampoVazio(data.motivo_incompleto) || isTextoNaoVazio(data.motivo_incompleto))
        && (isCampoVazio(data.observacao_operador) || isTextoNaoVazio(data.observacao_operador))
        && (isCampoVazio(data.local_separacao) || isTextoNaoVazio(data.local_separacao))
        && (isCampoVazio(data.prazo_limite) || isTextoNaoVazio(data.prazo_limite))
        && (isCampoVazio(data.empilhadeira_id) || isTextoNaoVazio(data.empilhadeira_id))
        && (isCampoVazio(data.empilhadeira_identificacao) || isTextoNaoVazio(data.empilhadeira_identificacao))
        && isPrioridadeValida(data.prioridade)
        && isStatusChamadoValido(data.status)
        && isTextoNaoVazio(data.criado_em)
        && (isCampoVazio(data.assumido_em) || isTextoNaoVazio(data.assumido_em))
        && (isCampoVazio(data.a_caminho_em) || isTextoNaoVazio(data.a_caminho_em))
        && (isCampoVazio(data.cheguei_em) || isTextoNaoVazio(data.cheguei_em))
        && (isCampoVazio(data.operador_nome) || isTextoNaoVazio(data.operador_nome))
        && (isCampoVazio(data.atualizado_em) || isTextoNaoVazio(data.atualizado_em))
        && (isCampoVazio(data.atualizado_por) || isTextoNaoVazio(data.atualizado_por))
        && (isCampoVazio(data.iniciado_em) || isTextoNaoVazio(data.iniciado_em))
        && (isCampoVazio(data.finalizado_em) || isTextoNaoVazio(data.finalizado_em))
        && (isCampoVazio(data.cancelado_em) || isTextoNaoVazio(data.cancelado_em))
        && isEmpilhadeiraCompativelComChamado(data);
    }

    function isEmpilhadeiraCompativelComChamado(data) {
      return (
        isCampoVazio(data.empilhadeira_id)
        && isCampoVazio(data.empilhadeira_identificacao)
      ) || (
        isTextoNaoVazio(data.empilhadeira_id)
        && isTextoNaoVazio(data.empilhadeira_identificacao)
        && exists(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id))
        && get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.empresa_id == data.empresa_id
        && get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.supermercado_id == data.supermercado_id
        && isStatusEmpilhadeiraCompativelComChamado(
          get(/databases/$(database)/documents/empilhadeiras/$(data.empilhadeira_id)).data.status
        )
      );
    }

    function isCriacaoChamadoValida() {
      return isChamadoBaseValido(request.resource.data)
        && (
          (request.resource.data.categoria == "operacional" && request.resource.data.status == "Aguardando")
          || (request.resource.data.categoria == "televendas" && request.resource.data.status == "Aberto")
        )
        && request.resource.data.operador_nome == null
        && request.resource.data.assumido_em == null
        && request.resource.data.a_caminho_em == null
        && request.resource.data.cheguei_em == null
        && request.resource.data.iniciado_em == null
        && request.resource.data.finalizado_em == null
        && request.resource.data.cancelado_em == null
        && request.resource.data.atualizado_em == null
        && request.resource.data.atualizado_por == null
        && request.resource.data.motivo_incompleto == null
        && request.resource.data.observacao_operador == null;
    }

    function isAtualizacaoChamadoValida() {
      return isChamadoBaseValido(request.resource.data)
        && request.resource.data.categoria == resource.data.categoria
        && request.resource.data.empresa_id == resource.data.empresa_id
        && request.resource.data.supermercado_id == resource.data.supermercado_id
        && request.resource.data.id == resource.data.id
        && request.resource.data.solicitante_nome == resource.data.solicitante_nome
        && request.resource.data.setor == resource.data.setor
        && request.resource.data.tipo_servico == resource.data.tipo_servico
        && request.resource.data.numero_pedido == resource.data.numero_pedido
        && request.resource.data.cliente == resource.data.cliente
        && request.resource.data.local_separacao == resource.data.local_separacao
        && request.resource.data.prazo_limite == resource.data.prazo_limite
        && request.resource.data.prioridade == resource.data.prioridade
        && request.resource.data.criado_em == resource.data.criado_em
        && isStatusChamadoValido(request.resource.data.status);
    }

    match /chamados/{id} {
      allow read: if isSignedIn() && canAccessEmpresa(resource.data.empresa_id);

      allow create: if isSignedIn()
        && request.resource.data.id == id
        && isCriacaoChamadoValida()
        && canAccessEmpresa(request.resource.data.empresa_id);

      allow update: if isSignedIn()
        && isAtualizacaoChamadoValida()
        && canAccessEmpresa(resource.data.empresa_id);

      allow delete: if isAdminGeral() || isAdminGeralByUserDoc();
    }

    match /empresas/{id} {
      allow read: if !isSignedIn() || canAccessEmpresa(id);
      allow write: if isAdminGeral() || isAdminGeralByUserDoc();
    }

    match /supermercados/{id} {
      allow read: if !isSignedIn() || canAccessEmpresa(resource.data.empresa_id);
      allow create: if hasAdminManagementAccess()
        && canAccessEmpresa(request.resource.data.empresa_id);
      allow update: if hasAdminManagementAccess()
        && canAccessEmpresa(resource.data.empresa_id)
        && canAccessEmpresa(request.resource.data.empresa_id)
        && (
          isPlatformAdminAccess()
          || request.resource.data.empresa_id == resource.data.empresa_id
        );
      allow delete: if hasAdminManagementAccess()
        && canAccessEmpresa(resource.data.empresa_id);
    }

    match /empilhadeiras/{id} {
      allow read: if isSignedIn() && canAccessEmpresa(resource.data.empresa_id);
      allow create: if hasAdminManagementAccess()
        && isEmpilhadeiraValida(request.resource.data, id);
      allow update: if (
          hasAdminManagementAccess()
          || isSupervisorDaUnidade(resource.data.supermercado_id)
        )
        && isEmpilhadeiraValida(request.resource.data, id)
        && request.resource.data.criado_em == resource.data.criado_em
        && (
          hasAdminManagementAccess()
          || (
            request.resource.data.empresa_id == resource.data.empresa_id
            && request.resource.data.supermercado_id == resource.data.supermercado_id
            && request.resource.data.identificacao == resource.data.identificacao
            && request.resource.data.modelo == resource.data.modelo
            && request.resource.data.numero_interno == resource.data.numero_interno
          )
        );
      allow delete: if hasAdminManagementAccess();
    }

    match /checklists_empilhadeira/{id} {
      allow read: if isSignedIn() && canAccessEmpresa(resource.data.empresa_id);
      allow create: if isChecklistEmpilhadeiraValido(request.resource.data, id)
        && canCreateChecklistEmpilhadeira(request.resource.data);
      allow update: if hasAdminManagementAccess()
        || isSupervisorDaUnidade(resource.data.supermercado_id);
      allow delete: if hasAdminManagementAccess();
    }

    match /manutencoes/{id} {
      allow read: if isSignedIn() && canAccessEmpresa(resource.data.empresa_id);
      allow create: if isManutencaoValida(request.resource.data, id)
        && canCreateManutencao(request.resource.data);
      allow update: if isManutencaoValida(request.resource.data, id)
        && canUpdateManutencao(resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.supermercado_id == resource.data.supermercado_id
        && request.resource.data.empilhadeira_id == resource.data.empilhadeira_id
        && request.resource.data.criado_por == resource.data.criado_por;
      allow delete: if hasAdminManagementAccess();
    }

    match /usuarios/{id} {
      allow read: if isSignedIn()
        && (
          request.auth.uid == id
          || canAccessEmpresa(resource.data.empresa_id)
        );

      allow create: if isSignedIn()
        && request.auth.uid == id
        && request.resource.data.id == request.auth.uid
        && request.resource.data.status == "Ativo"
        && isPerfilValido(request.resource.data.perfil)
        && isEmpresaVinculoValido(
          request.resource.data.perfil,
          request.resource.data.empresa_id
        )
        && isSupermercadoVinculoValido(
          request.resource.data.perfil,
          request.resource.data.empresa_id,
          request.resource.data.supermercado_id
        );

      allow update: if hasAdminManagementAccess()
        || (
          isSignedIn()
          && request.auth.uid == id
          && request.resource.data.id == resource.data.id
          && request.resource.data.nome == resource.data.nome
          && request.resource.data.email == resource.data.email
          && request.resource.data.perfil == resource.data.perfil
          && request.resource.data.empresa_id == resource.data.empresa_id
          && request.resource.data.status == resource.data.status
          && request.resource.data.criado_em == resource.data.criado_em
          && (
            request.resource.data.supermercado_id == resource.data.supermercado_id
            || isSupermercadoDaEmpresaAtivo(resource.data.empresa_id, request.resource.data.supermercado_id)
            || (resource.data.perfil == "Administrador Geral" && request.resource.data.supermercado_id == null)
            || (resource.data.perfil == "Administrador da Empresa" && request.resource.data.supermercado_id == null)
          )
        );

      allow delete: if hasAdminManagementAccess();
    }
  }
}
